# Файл .env.example

# API ключи (обязательные)
OPENAI_API_KEY=sk-000000000

# Настройки модели
OPENAI_MODEL=gpt-4-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Векторная база данных (если используете облачную)
QDRANT_URL=xxxxxx
QDRANT_API_KEY=00000000000000
QDRANT_COLLECTION_NAME=auto-generated-api-key
QDRANT_PORT=0000
QDRANT_GRPC_PORT=0000
QDRANT_PREFER_GRPC=True
QDRANT_TIMEOUT=60

# Локальные настройки
EMBEDDING_MODEL_PATH=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DB_PATH=./data/embeddings/chroma_db
TOP_K_RETRIEVAL=5